$TTL 604800
@       IN      SOA     ns.altay.sec. admin.altay.sec. (
                              2         ; Serial
                              604800    ; Refresh
                              86400     ; Retry
                              2419200   ; Expire
                              604800 )  ; Negative Cache TTL
;
@       IN      NS      ns.altay.sec.
ns      IN      A       192.168.57.2
www     IN      A       192.168.57.3
nfs     IN      A       192.168.57.4
